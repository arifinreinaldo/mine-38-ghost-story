# Supabase (optional — the free sample runs without these).
# Keys: Supabase Dashboard → Project Settings → API Keys.

# Client key — safe to ship to the browser (publishable, sb_publishable_...).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server ONLY — needed in Phase 2 (Stripe/RevenueCat webhook writing entitlements).
# Never prefix with VITE_ (that would bundle it into the client) and never commit it.
# Set it in Vercel as a server env var when you build the paywall.
# SUPABASE_SECRET_KEY=sb_secret_xxx
